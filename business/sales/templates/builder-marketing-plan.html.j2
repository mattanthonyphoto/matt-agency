{# ─── PHOTO BREAK — every 3rd content section, never adjacent to galleries ─── #}
{% set content_sections = ['snapshot','opportunity','website','gbp','social','content_engine','reviews','referrals','awards','roadmap','rhythm'] %}
{% set gallery_sections = ['gallery_1','gallery_2','gallery_3','case_study','cta','closing','numbers'] %}
{% if section_name in content_sections %}
  {% set ns = namespace(count=0, next_is_gallery=false) %}
  {% for s in sections[:loop.index] %}
    {% if s in content_sections %}{% set ns.count = ns.count + 1 %}{% endif %}
  {% endfor %}
  {% if loop.index < sections | length %}
    {% if sections[loop.index] in gallery_sections %}{% set ns.next_is_gallery = true %}{% endif %}
  {% endif %}
  {% if ns.count > 0 and ns.count % 3 == 0 and not ns.next_is_gallery and images is defined and images.breaks is defined %}
    {% set bi = (ns.count // 3 - 1) % (images.breaks | length) %}
    {% set brk = images.breaks[bi] %}
<div class="photo-break">
  <img src="{{ brk.url }}" alt="{{ brk.alt }}">
  <div class="photo-break-caption">{{ brk.caption | safe }}</div>
</div>
  {% endif %}
{% endif %}

{% endfor %}


<script>
(function(){
  'use strict';

  /* ═══════ LOADING SCREEN ═══════ */
  var loader = document.getElementById('loader');
  window.addEventListener('load', function(){
    setTimeout(function(){ loader.classList.add('done'); }, 1100);
  });

  /* ═══════ SCROLL PROGRESS ═══════ */
  var progressBar = document.getElementById('scrollProgress');
  function updateProgress(){
    var h = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + '%';
  }

  /* ═══════ COVER PARALLAX ═══════ */
  var coverImg = document.querySelector('.cover-image');
  function updateParallax(){
    if(window.scrollY < window.innerHeight){
      coverImg.style.transform = 'scale(1.08) translateY(' + (window.scrollY * 0.3) + 'px)';
    }
  }

  /* ═══════ PHOTO BREAK PARALLAX + KEN BURNS ═══════ */
  var photoBreakEls = document.querySelectorAll('.photo-break');
  function updatePhotoParallax(){
    photoBreakEls.forEach(function(pb){
      var rect = pb.getBoundingClientRect();
      var inView = rect.bottom > 0 && rect.top < window.innerHeight;
      pb.classList.toggle('in-view', inView);
    });
  }

  /* ═══════ SECTION NAV DOTS ═══════ */
  var sectionNav = document.getElementById('sectionNav');
  var navSections = document.querySelectorAll('[data-nav]');
  var navDots = [];
  navSections.forEach(function(sec){
    var dot = document.createElement('div');
    dot.className = 'section-nav-dot';
    dot.setAttribute('data-label', sec.getAttribute('data-nav'));
    dot.addEventListener('click', function(){ sec.scrollIntoView({ behavior:'smooth', block:'start' }); });
    sectionNav.appendChild(dot);
    navDots.push({ dot:dot, section:sec });
  });

  function updateNavDots(){
    var scrollY = window.scrollY;
    var winH = window.innerHeight;
    sectionNav.classList.toggle('visible', scrollY > winH * 0.5);
    var active = null;
    navDots.forEach(function(item){
      var rect = item.section.getBoundingClientRect();
      if(rect.top < winH * 0.5 && rect.bottom > winH * 0.3) active = item;
      item.dot.classList.remove('active');
    });
    if(active) active.dot.classList.add('active');
  }

  /* ═══════ SCROLL REVEAL ═══════ */
  var revealTargets = [];
  document.querySelectorAll('.section, .numbers').forEach(function(section){
    section.querySelectorAll('.eyebrow, h2, .lead, .scorecard, .stats, .channels, .pillars, .insight, .roadmap, .checklist, .numbers, .steps, .rhythm-grid, .comp-table').forEach(function(el, i){
      el.classList.add('reveal');
      if(i > 0 && i < 6) el.classList.add('reveal-delay-' + i);
      revealTargets.push(el);
    });
    section.querySelectorAll('.score-item, .channel, .pillar, .step, .num, .stat, .rm, .rhythm-card, .checklist-item').forEach(function(el, i){
      el.classList.add('reveal');
      el.classList.add('reveal-delay-' + Math.min(i + 1, 5));
      revealTargets.push(el);
    });
    Array.prototype.forEach.call(section.children, function(child){
      if(child.tagName === 'P' && !child.classList.contains('lead') && !child.classList.contains('cover-sub')){
        child.classList.add('reveal');
        revealTargets.push(child);
      }
    });
  });

  var revealObserver = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
        animateCounter(entry.target);
        animateRings(entry.target);
      }
    });
  }, { threshold:0.15, rootMargin:'0px 0px -40px 0px' });
  revealTargets.forEach(function(el){ revealObserver.observe(el); });

  /* ═══════ EYEBROW LINE ═══════ */
  var eyebrows = document.querySelectorAll('.eyebrow');
  var eyebrowObs = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){ entry.target.classList.add('visible'); eyebrowObs.unobserve(entry.target); }
    });
  }, { threshold:0.5 });
  eyebrows.forEach(function(eb){ eyebrowObs.observe(eb); });

  /* ═══════ HEADLINE UNDERLINE ═══════ */
  var headlines = document.querySelectorAll('h2');
  var headlineObs = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){ entry.target.classList.add('underlined'); headlineObs.unobserve(entry.target); }
    });
  }, { threshold:0.5 });
  headlines.forEach(function(h){ headlineObs.observe(h); });

  /* ═══════ NUMBER COUNTER ═══════ */
  function animateCounter(el){
    var valEl = el.querySelector('.stat-val, .num-val');
    if(!valEl || valEl.dataset.counted) return;
    valEl.dataset.counted = 'true';
    var text = valEl.textContent.trim();
    var hasPlus = text.indexOf('+') > -1;
    var hasPercent = text.indexOf('%') > -1;
    var suffix = hasPlus ? '+' : hasPercent ? '%' : '';
    var num = parseInt(text.replace(/[^0-9]/g,''), 10);
    if(isNaN(num) || num === 0) return;
    var duration = 1200;
    var start = performance.now();
    function ease(t){ return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2; }
    function tick(now){
      var t = Math.min((now - start) / duration, 1);
      valEl.textContent = Math.round(ease(t) * num) + suffix;
      if(t < 1) requestAnimationFrame(tick);
    }
    valEl.textContent = '0' + suffix;
    requestAnimationFrame(tick);
  }

  /* ═══════ SCORE RING ANIMATION ═══════ */
  function animateRings(el){
    var rings = el.querySelectorAll ? el.querySelectorAll('.score-ring') : [];
    rings.forEach(function(ring){
      if(ring.dataset.animated) return;
      ring.dataset.animated = 'true';
      var score = parseInt(ring.dataset.score, 10) || 0;
      var circumference = 226.2;
      var offset = circumference - (circumference * score / 100);
      ring.querySelector('.ring-fill').style.setProperty('--offset', offset);
      ring.classList.add('animated');
    });
  }
  // Also animate rings in scorecards observed directly
  var scorecardObs = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){ animateRings(entry.target); scorecardObs.unobserve(entry.target); }
    });
  }, { threshold:0.15 });
  document.querySelectorAll('.scorecard').forEach(function(sc){ scorecardObs.observe(sc); });

  /* ═══════ PHOTO BREAK CURTAIN ═══════ */
  var photoRevealObs = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){ entry.target.classList.add('revealed'); photoRevealObs.unobserve(entry.target); }
    });
  }, { threshold:0.1 });
  photoBreakEls.forEach(function(pb){ photoRevealObs.observe(pb); });

  /* ═══════ SCROLL INDICATOR ═══════ */
  var scrollIndicator = document.getElementById('scrollIndicator');
  function updateScrollIndicator(){
    scrollIndicator.classList.toggle('hidden', window.scrollY > 100);
  }

  /* ═══════ ROADMAP LINE DRAW ═══════ */
  var roadmapLine = document.getElementById('roadmapLine');
  var roadmap = document.querySelector('.roadmap');
  function updateRoadmapLine(){
    if(!roadmap || !roadmapLine) return;
    var rect = roadmap.getBoundingClientRect();
    var roadmapTop = rect.top + window.scrollY;
    var roadmapHeight = rect.height - 96;
    var scrollPos = window.scrollY + window.innerHeight * 0.6;
    var progress = Math.max(0, Math.min(1, (scrollPos - roadmapTop - 48) / roadmapHeight));
    roadmapLine.style.height = (progress * roadmapHeight) + 'px';
  }

  /* ═══════ CTA SMOOTH SCROLL ═══════ */
  var cta = document.querySelector('.cover-cta');
  if(cta){
    cta.addEventListener('click', function(e){
      e.preventDefault();
      var target = document.querySelector(this.getAttribute('href'));
      if(target) target.scrollIntoView({ behavior:'smooth', block:'start' });
    });
  }

  /* ═══════ SCROLL HANDLER ═══════ */
  var ticking = false;
  window.addEventListener('scroll', function(){
    if(!ticking){
      requestAnimationFrame(function(){
        updateProgress();
        updateParallax();
        updatePhotoParallax();
        updateScrollIndicator();
        updateRoadmapLine();
        updateNavDots();
        ticking = false;
      });
      ticking = true;
    }
  }, {passive:true});

  updateProgress();
  updateParallax();
  updatePhotoParallax();
  updateRoadmapLine();
  updateNavDots();
})();
</script>
</body>
</html>