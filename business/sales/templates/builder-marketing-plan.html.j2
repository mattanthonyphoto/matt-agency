<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marketing Playbook — {{ client.company }}</title>
<link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1A1A18;
    --paper: #F6F4F0;
    --gold: #C9A96E;
    --gold-dim: rgba(201,169,110,0.12);
    --gold-border: rgba(201,169,110,0.25);
    --gold-glow: rgba(201,169,110,0.06);
    --stone: #8A8579;
    --white: #FFFFFF;
    --light: #FAFAF8;
    --green: #4A7C59;
    --amber: #C49A3C;
    --red: #A65353;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { font-size:16px; -webkit-print-color-adjust:exact; print-color-adjust:exact; scroll-behavior:smooth; }
  body { background:var(--white); color:var(--ink); font-family:'DM Sans',sans-serif; font-weight:300; line-height:1.75; overflow-x:hidden; }

  /* ═══════════════════════════════════════
     COVER
     ═══════════════════════════════════════ */
  .cover {
    min-height:100vh; background:var(--ink); color:var(--paper);
    display:flex; flex-direction:column; justify-content:flex-end;
    position:relative; overflow:hidden;
  }
  .cover-image {
    position:absolute; top:0; left:0; width:100%; height:100%;
    background-size:cover; background-position:center 25%;
    will-change:transform; transition:transform 0.1s linear;
  }
  .cover-image::after {
    content:''; position:absolute; top:0; left:0; width:100%; height:100%;
    background:linear-gradient(
      to bottom,
      rgba(26,26,24,0.3) 0%,
      rgba(26,26,24,0.2) 20%,
      rgba(26,26,24,0.5) 50%,
      rgba(26,26,24,0.92) 75%,
      rgba(26,26,24,0.99) 100%
    );
  }
  .cover-top {
    position:absolute; top:0; left:0; right:0; z-index:3;
    padding:40px 60px; display:flex; justify-content:space-between; align-items:center;
  }
  .cover-logo {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.65rem;
    letter-spacing:0.35em; text-transform:uppercase; color:rgba(246,244,240,0.6);
  }
  .cover-date {
    font-family:'Josefin Sans',sans-serif; font-size:0.65rem;
    letter-spacing:0.2em; color:rgba(246,244,240,0.4);
  }
  .cover-content {
    position:relative; z-index:2; padding:0 60px 80px; max-width:760px;
  }
  .cover-eyebrow {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.65rem;
    letter-spacing:0.4em; text-transform:uppercase; color:var(--gold);
    margin-bottom:20px; display:flex; align-items:center; gap:16px;
  }
  .cover-eyebrow::before { content:''; width:32px; height:1px; background:var(--gold); }
  .cover h1 {
    font-family:'Cormorant Garamond',serif; font-weight:400;
    font-size:clamp(2.8rem,5.5vw,4.8rem); line-height:1.08; margin-bottom:20px;
    letter-spacing:-0.01em;
    text-shadow:0 2px 40px rgba(0,0,0,0.5), 0 4px 80px rgba(0,0,0,0.3);
  }
  .cover h1 em { font-style:italic; font-weight:500; color:var(--gold); }
  .cover-sub {
    font-size:1rem; color:rgba(246,244,240,0.75); max-width:520px;
    line-height:1.8; margin-bottom:56px;
    text-shadow:0 1px 20px rgba(0,0,0,0.4);
  }
  .cover-meta-bar {
    display:flex; gap:48px; padding-top:32px;
    border-top:1px solid rgba(201,169,110,0.15);
  }
  .cover-meta-item {
    font-size:0.75rem; color:rgba(246,244,240,0.35); line-height:1.8;
  }
  .cover-meta-item strong {
    display:block; color:rgba(246,244,240,0.7); font-weight:400;
    font-family:'Josefin Sans',sans-serif; font-size:0.6rem;
    letter-spacing:0.15em; text-transform:uppercase; margin-bottom:2px;
  }
  .cover-cta {
    display:inline-flex; align-items:center; gap:10px;
    margin-top:32px; padding:12px 28px;
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.6rem;
    letter-spacing:0.25em; text-transform:uppercase;
    color:var(--paper); border:1px solid rgba(246,244,240,0.25);
    text-decoration:none; cursor:pointer;
    transition:all 0.4s cubic-bezier(0.16,1,0.3,1);
    opacity:0; animation:coverFade 0.9s 1.5s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .cover-cta:hover { border-color:var(--gold); color:var(--gold); padding-right:36px; }
  .cover-cta-arrow { display:inline-block; transition:transform 0.3s ease; font-size:0.8rem; }
  .cover-cta:hover .cover-cta-arrow { transform:translateY(3px); }

  /* ═══════════════════════════════════════
     LAYOUT
     ═══════════════════════════════════════ */
  .section { padding:120px 60px; max-width:1000px; margin:0 auto; }
  .section.wide { max-width:1200px; }
  .section.dark { background:var(--ink); color:var(--paper); max-width:100%; }
  .section.cream { background:var(--paper); }
  .section.light { background:var(--light); }
  .section.dark .section-inner { max-width:1000px; margin:0 auto; }

  .eyebrow {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.6rem;
    letter-spacing:0.35em; text-transform:uppercase; color:var(--gold);
    margin-bottom:16px; display:flex; align-items:center; gap:14px;
  }
  .eyebrow::before { content:''; width:0; height:1px; background:var(--gold); transition:width 0.6s 0.2s cubic-bezier(0.16,1,0.3,1); }
  .eyebrow.visible::before { width:24px; }

  h2 {
    font-family:'Cormorant Garamond',serif; font-weight:400;
    font-size:2.6rem; line-height:1.12; margin-bottom:32px;
    letter-spacing:-0.01em; text-wrap:balance;
  }
  h2 em { font-style:italic; font-weight:500; position:relative; display:inline; }
  h2 em::after {
    content:''; position:absolute; bottom:2px; left:0;
    width:0; height:1.5px;
    background:linear-gradient(90deg, var(--gold), rgba(201,169,110,0.3));
    transition:width 1s 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  h2.underlined em::after { width:100%; }
  h3 {
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.75rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--stone);
    margin:56px 0 20px;
  }
  p { margin-bottom:20px; font-size:0.95rem; }
  .lead { font-size:1.05rem; line-height:1.9; color:var(--stone); text-wrap:pretty; }

  /* ═══════════════════════════════════════
     SCORECARD
     ═══════════════════════════════════════ */
  .scorecard {
    display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
    margin:56px 0; background:var(--gold-dim);
  }
  .score-item {
    background:var(--white); text-align:center; padding:40px 16px;
    position:relative;
  }
  .section.cream .score-item { background:var(--paper); }
  .score-ring {
    width:80px; height:80px; margin:0 auto 16px; position:relative;
  }
  .score-ring svg { width:100%; height:100%; transform:rotate(-90deg); }
  .score-ring circle {
    fill:none; stroke-width:3; cx:40; cy:40; r:36;
  }
  .score-ring .ring-bg { stroke:var(--gold-dim); }
  .score-ring .ring-fill {
    stroke:var(--gold); stroke-linecap:round;
    stroke-dasharray:226.2; stroke-dashoffset:226.2;
    transition:stroke-dashoffset 1.5s 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .score-ring.animated .ring-fill { stroke-dashoffset:var(--offset); }
  .score-ring .ring-fill.good { stroke:var(--green); }
  .score-ring .ring-fill.ok { stroke:var(--gold); }
  .score-ring .ring-fill.poor { stroke:var(--red); }
  .score-grade {
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    font-family:'Cormorant Garamond',serif; font-size:1.4rem; font-weight:500;
    color:var(--ink);
  }
  .score-label {
    font-family:'Josefin Sans',sans-serif; font-size:0.55rem;
    letter-spacing:0.25em; text-transform:uppercase; color:var(--stone);
  }

  /* ═══════════════════════════════════════
     STATS
     ═══════════════════════════════════════ */
  .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; margin:56px 0; background:var(--gold-dim); }
  .stat { background:var(--white); text-align:center; padding:36px 16px; }
  .section.cream .stat { background:var(--paper); }
  .stat-val {
    font-family:'Cormorant Garamond',serif; font-size:3rem; font-weight:500;
    color:var(--gold); display:block; line-height:1; margin-bottom:10px;
    text-shadow:0 0 40px rgba(201,169,110,0.15);
  }
  .stat-lbl {
    font-family:'Josefin Sans',sans-serif; font-size:0.55rem;
    letter-spacing:0.25em; text-transform:uppercase; color:var(--stone);
  }

  /* ═══════════════════════════════════════
     CHANNEL CARDS (2-column)
     ═══════════════════════════════════════ */
  .channels { display:grid; grid-template-columns:1fr 1fr; gap:1px; margin:56px 0; background:var(--gold-dim); }
  .channel {
    background:var(--white); padding:40px 36px; position:relative;
    transition:all 0.3s cubic-bezier(0.16,1,0.3,1); border-left:3px solid transparent;
  }
  .channel:hover { border-left-color:var(--gold); background:var(--light); }
  .channel-status {
    position:absolute; top:20px; right:20px;
    font-family:'Josefin Sans',sans-serif; font-size:0.5rem;
    letter-spacing:0.2em; text-transform:uppercase; padding:4px 12px;
  }
  .channel-status.active { color:var(--green); border:1px solid rgba(74,124,89,0.3); }
  .channel-status.needs-work { color:var(--amber); border:1px solid rgba(196,154,60,0.3); }
  .channel-status.missing { color:var(--red); border:1px solid rgba(166,83,83,0.3); }
  .channel h4 {
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.7rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--gold); margin-bottom:20px;
  }
  .channel ul { list-style:none; }
  .channel li {
    font-size:0.85rem; padding:8px 0 8px 24px; position:relative;
    color:var(--stone); border-bottom:1px solid rgba(26,26,24,0.04);
  }
  .channel li:last-child { border:none; }
  .channel li::before {
    content:''; position:absolute; left:0; top:16px;
    width:8px; height:1px; background:var(--gold);
  }

  /* ═══════════════════════════════════════
     CHECKLIST
     ═══════════════════════════════════════ */
  .checklist { margin:40px 0; }
  .checklist-item {
    display:flex; align-items:flex-start; gap:16px; padding:14px 0;
    border-bottom:1px solid rgba(26,26,24,0.06);
  }
  .checklist-item:last-child { border:none; }
  .checklist-icon {
    flex-shrink:0; width:20px; height:20px; border:1.5px solid var(--gold-border);
    border-radius:3px; margin-top:2px; position:relative;
  }
  .checklist-icon::after {
    content:''; position:absolute; top:3px; left:6px;
    width:5px; height:9px; border:solid var(--gold); border-width:0 1.5px 1.5px 0;
    transform:rotate(45deg); opacity:0;
  }
  .checklist-item.checked .checklist-icon { border-color:var(--gold); background:var(--gold-dim); }
  .checklist-item.checked .checklist-icon::after { opacity:1; }
  .checklist-text { font-size:0.9rem; color:var(--ink); }
  .checklist-text span { display:block; font-size:0.8rem; color:var(--stone); margin-top:2px; }

  /* ═══════════════════════════════════════
     INSIGHT BOX
     ═══════════════════════════════════════ */
  .insight {
    background:var(--light); padding:48px 56px; margin:56px 0;
    position:relative; border:1px solid rgba(201,169,110,0.08);
    box-shadow:0 8px 32px rgba(0,0,0,0.03);
  }
  .insight::before {
    content:''; position:absolute; top:0; left:0; bottom:0;
    width:3px; background:var(--gold);
    box-shadow:4px 0 16px rgba(201,169,110,0.08);
  }
  .insight h4 {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.65rem;
    letter-spacing:0.25em; text-transform:uppercase; color:var(--gold); margin-bottom:20px;
  }
  .insight p { font-size:0.9rem; margin-bottom:10px; }
  .insight p:last-child { margin-bottom:0; }

  /* ═══════════════════════════════════════
     NUMBERS BAR
     ═══════════════════════════════════════ */
  .numbers {
    display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    margin:56px 0; background:var(--gold-dim);
  }
  .num { background:var(--ink); text-align:center; padding:48px 24px; }
  .num-val {
    font-family:'Cormorant Garamond',serif; font-size:3.5rem;
    font-weight:500; color:var(--gold); display:block; line-height:1; margin-bottom:10px;
    text-shadow:0 0 60px rgba(201,169,110,0.25), 0 0 120px rgba(201,169,110,0.1);
  }
  .num-lbl {
    font-family:'Josefin Sans',sans-serif; font-size:0.55rem;
    letter-spacing:0.25em; text-transform:uppercase; color:rgba(246,244,240,0.4);
  }

  /* ═══════════════════════════════════════
     ROADMAP (90-day)
     ═══════════════════════════════════════ */
  .roadmap { margin:56px 0; position:relative; }
  .roadmap-line {
    position:absolute; left:200px; top:48px; width:2px;
    height:0; background:var(--gold);
    transition:height 0.05s linear; z-index:1;
    box-shadow:0 0 6px rgba(201,169,110,0.3);
  }
  .roadmap-line::after {
    content:''; position:absolute; bottom:-4px; left:-3px;
    width:8px; height:8px; border-radius:50%;
    background:var(--gold); box-shadow:0 0 12px rgba(201,169,110,0.5);
  }
  .rm {
    display:grid; grid-template-columns:200px 1fr; gap:0;
    border-bottom:1px solid rgba(26,26,24,0.06); min-height:0;
  }
  .rm:last-child { border:none; }
  .rm-left {
    padding:40px 32px 40px 0; border-right:2px solid var(--gold-dim);
    position:relative;
  }
  .rm-left::after {
    content:''; position:absolute; right:-5px; top:48px;
    width:8px; height:8px; border-radius:50%; background:var(--gold);
  }
  .rm-period {
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.6rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--gold); margin-bottom:4px;
  }
  .rm-label {
    font-family:'Cormorant Garamond',serif; font-size:1.3rem;
    font-weight:400; font-style:italic; color:var(--ink); line-height:1.3;
  }
  .rm-right { padding:40px 0 40px 40px; }
  .rm-right ul { list-style:none; }
  .rm-right li {
    font-size:0.85rem; padding:6px 0 6px 24px; position:relative; color:var(--stone);
  }
  .rm-right li::before {
    content:''; position:absolute; left:0; top:14px;
    width:8px; height:1px; background:var(--gold);
  }

  /* ═══════════════════════════════════════
     MONTHLY RHYTHM (grid)
     ═══════════════════════════════════════ */
  .rhythm-grid {
    display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    margin:56px 0; background:var(--gold-dim);
  }
  .rhythm-card {
    background:var(--white); padding:36px 32px;
    transition:background 0.3s ease, box-shadow 0.3s ease;
  }
  .rhythm-card:hover { background:var(--light); box-shadow:0 4px 24px rgba(0,0,0,0.04); }
  .rhythm-freq {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.5rem;
    letter-spacing:0.25em; text-transform:uppercase; color:var(--gold); margin-bottom:8px;
  }
  .rhythm-card h4 {
    font-family:'DM Sans',sans-serif; font-weight:500; font-size:0.95rem;
    margin-bottom:12px;
  }
  .rhythm-card ul { list-style:none; }
  .rhythm-card li {
    font-size:0.8rem; padding:5px 0 5px 20px; position:relative; color:var(--stone);
  }
  .rhythm-card li::before {
    content:''; position:absolute; left:0; top:13px;
    width:6px; height:1px; background:var(--gold);
  }

  /* ═══════════════════════════════════════
     STEPS (next actions)
     ═══════════════════════════════════════ */
  .steps { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; margin:56px 0; background:var(--gold-dim); }
  .step { background:var(--white); padding:40px 32px; transition:background 0.3s ease, box-shadow 0.3s ease; }
  .step:hover { background:var(--light); box-shadow:0 4px 24px rgba(0,0,0,0.04); }
  .step-num {
    font-family:'Cormorant Garamond',serif; font-size:3rem;
    font-weight:400; color:var(--gold); line-height:1; margin-bottom:16px; display:block;
    text-shadow:0 0 40px rgba(201,169,110,0.15);
  }
  .step h4 { font-family:'DM Sans',sans-serif; font-weight:500; font-size:0.95rem; margin-bottom:10px; }
  .step p { font-size:0.82rem; color:var(--stone); margin-bottom:0; }

  /* ═══════════════════════════════════════
     PHOTO BREAK
     ═══════════════════════════════════════ */
  .photo-break {
    width:100%; height:45vh; min-height:320px; max-height:480px;
    position:relative; overflow:hidden;
    clip-path:inset(0 0 0 0); transition:clip-path 1.2s cubic-bezier(0.16,1,0.3,1);
  }
  .photo-break.revealed { clip-path:inset(0 0 0 0); }
  .photo-break img {
    width:100%; height:120%; object-fit:cover; display:block;
    position:absolute; top:-10%; left:0;
    filter:brightness(0.85); transition:filter 0.8s cubic-bezier(0.16,1,0.3,1);
    will-change:transform;
  }
  .photo-break:hover img { filter:brightness(0.95); }
  .photo-break::before {
    content:''; position:absolute; top:0; left:0; right:0; height:80px;
    background:linear-gradient(rgba(26,26,24,0.15), transparent); z-index:1; pointer-events:none;
  }
  .photo-break::after {
    content:''; position:absolute; bottom:0; left:0; right:0; height:120px;
    background:linear-gradient(transparent, rgba(26,26,24,0.6)); z-index:1; pointer-events:none;
  }
  .photo-break-caption {
    position:absolute; bottom:0; left:0; right:0; z-index:2; padding:24px 60px;
    font-family:'Josefin Sans',sans-serif; font-size:0.5rem;
    letter-spacing:0.3em; text-transform:uppercase; color:rgba(246,244,240,0.5);
  }
  .photo-break.in-view img { animation:kenBurns 12s ease-in-out infinite alternate; }
  @keyframes kenBurns {
    0% { transform:scale(1) translateY(0); }
    100% { transform:scale(1.06) translateY(-8px); }
  }

  /* ═══════════════════════════════════════
     CONTENT PILLAR CARDS
     ═══════════════════════════════════════ */
  .pillars { display:grid; grid-template-columns:1fr 1fr; gap:1px; margin:56px 0; background:var(--gold-dim); }
  .pillar {
    background:var(--white); padding:40px 36px;
    transition:all 0.3s cubic-bezier(0.16,1,0.3,1); border-left:3px solid transparent;
  }
  .pillar:hover { border-left-color:var(--gold); background:var(--light); }
  .pillar h4 {
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.7rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--gold); margin-bottom:8px;
  }
  .pillar-type {
    font-family:'Josefin Sans',sans-serif; font-size:0.5rem;
    letter-spacing:0.15em; text-transform:uppercase; color:var(--stone);
    margin-bottom:16px;
  }
  .pillar p { font-size:0.85rem; color:var(--stone); margin-bottom:0; }

  /* ═══════════════════════════════════════
     COMPETITOR TABLE
     ═══════════════════════════════════════ */
  .comp-table {
    width:100%; border-collapse:collapse; margin:56px 0;
  }
  .comp-table th {
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.6rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--gold);
    padding:16px 20px; text-align:left; border-bottom:2px solid var(--gold-dim);
  }
  .comp-table td {
    font-size:0.85rem; padding:14px 20px; color:var(--stone);
    border-bottom:1px solid rgba(26,26,24,0.06);
  }
  .comp-table tr:last-child td { border:none; }
  .comp-table .highlight td {
    color:var(--ink); font-weight:400; background:var(--gold-glow);
  }
  .comp-dot {
    display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:8px;
  }
  .comp-dot.good { background:var(--green); }
  .comp-dot.ok { background:var(--gold); }
  .comp-dot.poor { background:var(--red); }

  /* ═══════════════════════════════════════
     CASE STUDY
     ═══════════════════════════════════════ */
  .case-study-header {
    position:relative; overflow:hidden; min-height:360px;
    display:flex; align-items:flex-end; margin-bottom:56px;
  }
  .case-study-header img {
    position:absolute; top:0; left:0; width:100%; height:100%;
    object-fit:cover; filter:brightness(0.7);
  }
  .case-study-header-content {
    position:relative; z-index:2; padding:40px 48px; width:100%;
    background:linear-gradient(transparent, rgba(26,26,24,0.85));
  }
  .case-study-header-content h4 {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.6rem;
    letter-spacing:0.3em; text-transform:uppercase; color:var(--gold); margin-bottom:8px;
  }
  .case-study-header-content h3 {
    font-family:'Cormorant Garamond',serif; font-weight:400; font-size:2rem;
    color:var(--paper); margin:0; letter-spacing:-0.01em; text-transform:none;
  }
  .case-study-header-content h3 em { font-style:italic; font-weight:500; color:var(--gold); }
  .case-study-stats {
    display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
    background:var(--gold-dim); margin:40px 0;
  }
  .case-study-stat {
    background:var(--ink); text-align:center; padding:32px 16px;
  }
  .case-study-stat .num-val {
    font-family:'Cormorant Garamond',serif; font-size:2.4rem;
    font-weight:500; color:var(--gold); display:block; line-height:1; margin-bottom:8px;
  }
  .case-study-stat .num-lbl {
    font-family:'Josefin Sans',sans-serif; font-size:0.5rem;
    letter-spacing:0.2em; text-transform:uppercase; color:rgba(246,244,240,0.4);
  }
  .case-study-gallery {
    display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:3px;
    margin:40px 0;
  }
  .case-study-gallery img {
    width:100%; height:180px; object-fit:cover; display:block;
    filter:brightness(0.92); transition:filter 0.4s ease;
  }
  .case-study-gallery img:hover { filter:brightness(1.05); }
  .case-study-link {
    display:inline-flex; align-items:center; gap:10px;
    margin-top:24px; padding:12px 28px;
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.6rem;
    letter-spacing:0.25em; text-transform:uppercase;
    color:var(--gold); border:1px solid var(--gold-border);
    text-decoration:none; transition:all 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .case-study-link:hover { border-color:var(--gold); background:var(--gold-dim); }

  /* ═══════════════════════════════════════
     BROWSER MOCKUP (Website Slider)
     ═══════════════════════════════════════ */
  .browser-mockup {
    max-width:940px; margin:48px auto; border-radius:10px;
    overflow:hidden;
    box-shadow:0 30px 80px rgba(26,26,24,0.18), 0 10px 30px rgba(26,26,24,0.1);
    animation:browserGlow 4s ease-in-out infinite alternate;
  }
  @keyframes browserGlow {
    0%   { box-shadow:0 30px 80px rgba(26,26,24,0.18), 0 10px 30px rgba(26,26,24,0.1); }
    100% { box-shadow:0 30px 80px rgba(26,26,24,0.18), 0 10px 30px rgba(26,26,24,0.1), 0 0 60px rgba(201,169,110,0.06); }
  }
  .browser-bar {
    background:#2a2a28; padding:14px 18px;
    display:flex; align-items:center; gap:8px;
  }
  .browser-dot {
    width:11px; height:11px; border-radius:50%;
  }
  .browser-dot:nth-child(1) { background:#ff5f57; }
  .browser-dot:nth-child(2) { background:#ffbd2e; }
  .browser-dot:nth-child(3) { background:#28c840; }
  .browser-url {
    flex:1; background:#1a1a18; border-radius:6px;
    padding:7px 14px; margin-left:10px;
    font-size:12px; color:#8a8579;
    font-family:'DM Sans',-apple-system,sans-serif;
    letter-spacing:0.02em;
  }
  .browser-viewport {
    height:520px; overflow:hidden; position:relative;
    background:#1a1a18;
  }
  .browser-viewport img {
    width:100%; display:block;
    animation:webScroll 20s cubic-bezier(0.45,0,0.55,1) infinite;
  }
  @keyframes webScroll {
    0%,20%   { transform:translateY(0); }
    45%,55%  { transform:translateY(-1500px); }
    80%,100% { transform:translateY(0); }
  }

  /* ═══════════════════════════════════════
     CTA + FOOTER — Unified end block
     ═══════════════════════════════════════ */
  .cta-banner {
    background:var(--ink); color:var(--paper); padding:200px 60px 160px;
    text-align:center; position:relative; overflow:hidden;
  }
  .cta-banner .section-inner { max-width:680px; margin:0 auto; position:relative; z-index:2; }
  .cta-banner-image {
    position:absolute; top:0; left:0; width:100%; height:100%;
  }
  .cta-banner-image img {
    width:100%; height:100%; object-fit:cover; display:block;
  }
  .cta-banner-image::after {
    content:''; position:absolute; top:0; left:0; width:100%; height:100%;
    background:linear-gradient(
      to bottom,
      rgba(26,26,24,0.6) 0%,
      rgba(26,26,24,0.45) 30%,
      rgba(26,26,24,0.5) 60%,
      rgba(26,26,24,0.85) 100%
    );
  }
  .cta-banner-bg { display:none; }
  .cta-banner .eyebrow { display:none; }
  .cta-banner h2 {
    text-align:center; color:var(--paper);
    font-family:'Cormorant Garamond',serif; font-weight:400;
    font-size:clamp(1.8rem,3.5vw,2.8rem); line-height:1.2;
    margin-bottom:24px;
  }
  .cta-banner h2 em { font-style:italic; color:var(--gold); }
  .cta-banner p {
    color:rgba(246,244,240,0.6); text-align:center;
    max-width:520px; margin:0 auto 12px;
    font-size:0.9rem; line-height:1.8;
  }
  .cta-banner p:last-of-type { margin-bottom:48px; }
  .cta-btn {
    display:inline-flex; align-items:center; gap:12px;
    padding:18px 48px;
    font-family:'Josefin Sans',sans-serif; font-weight:400; font-size:0.65rem;
    letter-spacing:0.3em; text-transform:uppercase;
    color:var(--ink); background:var(--gold);
    text-decoration:none; border:none; cursor:pointer;
    transition:all 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .cta-btn:hover {
    background:var(--paper); color:var(--ink);
    transform:translateY(-2px);
  }
  .cta-btn-arrow { font-size:0.9rem; transition:transform 0.3s ease; }
  .cta-btn:hover .cta-btn-arrow { transform:translateX(4px); }
  .cta-secondary {
    margin-top:16px; font-size:0.8rem; color:rgba(246,244,240,0.4);
  }
  .cta-secondary a {
    color:var(--gold); text-decoration:underline;
    text-underline-offset:3px; text-decoration-color:rgba(201,169,110,0.4);
  }
  .cta-details { display:none; }

  /* ═══════════════════════════════════════
     INLINE GALLERY (sprinkled between sections)
     ═══════════════════════════════════════ */
  .inline-gallery {
    display:grid; grid-template-columns:1fr 1fr; gap:3px;
    background:var(--ink);
  }
  .inline-gallery.three-col { grid-template-columns:1fr 1fr 1fr; }
  .inline-gallery.single-hero {
    display:block; position:relative; overflow:hidden;
    height:55vh; min-height:360px; max-height:560px;
  }
  .inline-gallery.single-hero img {
    width:100%; height:100%; object-fit:cover; display:block;
    filter:brightness(0.82);
    transition:filter 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .inline-gallery.single-hero:hover img { filter:brightness(0.9); }
  .inline-gallery.single-hero .inline-gallery-caption {
    position:absolute; bottom:0; left:0; right:0; z-index:2;
    padding:28px 60px;
    background:linear-gradient(transparent, rgba(26,26,24,0.7));
  }
  .inline-gallery img {
    width:100%; height:260px; object-fit:cover; display:block;
    filter:brightness(0.88); transition:filter 0.5s ease, transform 0.5s ease;
  }
  .inline-gallery img:hover { filter:brightness(1.02); transform:scale(1.01); }
  .inline-gallery-caption {
    grid-column:1/-1; background:var(--ink); padding:16px 60px;
    font-family:'Josefin Sans',sans-serif; font-size:0.5rem;
    letter-spacing:0.3em; text-transform:uppercase;
    color:rgba(246,244,240,0.25); text-align:center;
  }

  @media (max-width:768px) {
    .case-study-stats { grid-template-columns:1fr 1fr; }
    .case-study-gallery { grid-template-columns:1fr 1fr; }
    .case-study-gallery img { height:140px; }
    .browser-viewport { height:300px; }
    .browser-viewport img { animation-name:webScrollMobile; }
    @keyframes webScrollMobile {
      0%,20%   { transform:translateY(0); }
      45%,55%  { transform:translateY(-1000px); }
      80%,100% { transform:translateY(0); }
    }
    .cta-banner { padding:100px 32px 80px; }
    .footer-locations { padding:32px 32px; gap:20px; }
    .footer-bar { flex-direction:column; gap:12px; padding:24px 32px; align-items:center; }
    .footer-note { padding:16px 32px; }
    .inline-gallery { grid-template-columns:1fr; }
    .inline-gallery.three-col { grid-template-columns:1fr; }
    .inline-gallery img { height:200px; }
    .inline-gallery.single-hero { height:40vh; min-height:240px; }
    .inline-gallery.single-hero .inline-gallery-caption { padding:20px 32px; }
  }

  /* ═══════════════════════════════════════
     FOOTER — Locations bar + contact row
     ═══════════════════════════════════════ */
  .footer {
    background:var(--ink); padding:0; text-align:center; position:relative;
  }
  .footer-locations {
    display:flex; justify-content:center; gap:32px; flex-wrap:wrap;
    padding:40px 60px;
    border-top:1px solid rgba(246,244,240,0.06);
  }
  .footer-locations span {
    font-family:'Josefin Sans',sans-serif; font-size:0.55rem;
    letter-spacing:0.25em; text-transform:uppercase;
    color:rgba(246,244,240,0.3);
  }
  .footer-bar {
    display:flex; justify-content:space-between; align-items:center;
    padding:24px 60px;
    border-top:1px solid rgba(246,244,240,0.06);
  }
  .footer-bar-item {
    font-family:'DM Sans',sans-serif; font-size:0.7rem;
    color:rgba(246,244,240,0.3); letter-spacing:0.02em;
  }
  .footer-bar-item strong {
    font-family:'Josefin Sans',sans-serif; font-weight:400;
    font-size:0.5rem; letter-spacing:0.2em; text-transform:uppercase;
    color:rgba(246,244,240,0.15); margin-right:8px;
  }
  .footer-bar-item a {
    color:rgba(246,244,240,0.3); text-decoration:none;
    transition:color 0.3s ease;
  }
  .footer-bar-item a:hover { color:var(--gold); }
  .footer-note {
    padding:20px 60px;
    font-size:0.5rem; letter-spacing:0.2em;
    text-transform:uppercase; font-family:'Josefin Sans',sans-serif;
    color:rgba(246,244,240,0.08); text-align:center;
    border-top:1px solid rgba(246,244,240,0.04);
  }

  /* ═══════════════════════════════════════
     SCROLL PROGRESS BAR
     ═══════════════════════════════════════ */
  .scroll-progress {
    position:fixed; top:0; left:0; height:2px; width:0%;
    background:linear-gradient(90deg, var(--gold), rgba(201,169,110,0.4));
    z-index:9999; transition:width 0.05s linear;
    box-shadow:0 0 8px rgba(201,169,110,0.3);
  }

  /* ═══════════════════════════════════════
     SCROLL REVEAL
     ═══════════════════════════════════════ */
  .reveal {
    opacity:0; transform:translateY(32px);
    transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal.visible { opacity:1; transform:translateY(0); }
  .reveal-delay-1 { transition-delay:0.1s; }
  .reveal-delay-2 { transition-delay:0.2s; }
  .reveal-delay-3 { transition-delay:0.3s; }
  .reveal-delay-4 { transition-delay:0.4s; }
  .reveal-delay-5 { transition-delay:0.5s; }

  /* Cover cascade */
  .cover .cover-eyebrow, .cover h1, .cover .cover-sub, .cover .cover-meta-bar {
    opacity:0; transform:translateY(24px);
    animation:coverFade 0.9s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .cover .cover-eyebrow { animation-delay:0.3s; }
  .cover h1 { animation-delay:0.6s; }
  .cover .cover-sub { animation-delay:0.9s; }
  .cover .cover-meta-bar { animation-delay:1.2s; }
  @keyframes coverFade { to { opacity:1; transform:translateY(0); } }

  /* ═══════════════════════════════════════
     FILM GRAIN
     ═══════════════════════════════════════ */
  .grain-section::after {
    content:''; position:absolute; top:0; left:0; right:0; bottom:0;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size:128px 128px; pointer-events:none; z-index:0; opacity:0.5;
  }
  .grain-section { position:relative; }
  .grain-section > * { position:relative; z-index:1; }

  /* ═══════════════════════════════════════
     SECTION NAV DOTS
     ═══════════════════════════════════════ */
  .section-nav {
    position:fixed; right:24px; top:50%; transform:translateY(-50%);
    z-index:9998; display:flex; flex-direction:column; gap:12px;
    opacity:0; transition:opacity 0.4s ease;
  }
  .section-nav.visible { opacity:1; }
  .section-nav-dot {
    width:8px; height:8px; border-radius:50%;
    background:transparent; border:1px solid var(--stone);
    cursor:pointer; transition:all 0.3s ease; position:relative;
  }
  .section-nav-dot:hover { border-color:var(--gold); transform:scale(1.3); }
  .section-nav-dot.active {
    background:var(--gold); border-color:var(--gold);
    box-shadow:0 0 8px rgba(201,169,110,0.4);
  }
  .section-nav-dot::before {
    content:attr(data-label);
    position:absolute; right:20px; top:50%; transform:translateY(-50%);
    font-family:'Josefin Sans',sans-serif; font-size:0.5rem;
    letter-spacing:0.15em; text-transform:uppercase; color:var(--gold);
    white-space:nowrap; opacity:0; pointer-events:none; transition:opacity 0.3s ease, right 0.3s ease;
  }
  .section-nav-dot:hover::before { opacity:1; right:24px; }

  /* ═══════════════════════════════════════
     SCROLL INDICATOR
     ═══════════════════════════════════════ */
  .scroll-indicator {
    position:absolute; bottom:40px; left:50%;
    transform:translateX(-50%); display:flex; flex-direction:column;
    align-items:center; gap:8px;
    opacity:0; animation:coverFade 0.9s 1.8s cubic-bezier(0.16,1,0.3,1) forwards;
    transition:opacity 0.4s ease;
  }
  .scroll-indicator.hidden { opacity:0 !important; }
  .scroll-indicator-text {
    font-family:'Josefin Sans',sans-serif; font-size:0.45rem;
    letter-spacing:0.3em; text-transform:uppercase; color:rgba(246,244,240,0.3);
  }
  .scroll-indicator-line {
    width:1px; height:32px; position:relative; overflow:hidden;
    background:rgba(246,244,240,0.1);
  }
  .scroll-indicator-line::after {
    content:''; position:absolute; top:-100%; left:0;
    width:100%; height:100%; background:var(--gold);
    animation:scrollPulse 2s cubic-bezier(0.16,1,0.3,1) infinite;
  }
  @keyframes scrollPulse { 0% { top:-100%; } 50% { top:100%; } 100% { top:100%; } }

  /* ═══════════════════════════════════════
     LOADING SCREEN
     ═══════════════════════════════════════ */
  .loader {
    position:fixed; top:0; left:0; right:0; bottom:0;
    background:var(--ink); z-index:99999;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1), visibility 0.8s;
  }
  .loader.done { opacity:0; visibility:hidden; pointer-events:none; }
  .loader-brand {
    font-family:'Josefin Sans',sans-serif; font-weight:300; font-size:0.65rem;
    letter-spacing:0.6em; text-transform:uppercase; color:var(--paper);
    opacity:0; animation:loaderIn 0.6s 0.15s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .loader-sub {
    font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.9rem;
    color:var(--stone); margin-top:8px;
    opacity:0; animation:loaderIn 0.6s 0.4s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .loader-line {
    width:80px; height:1px; background:var(--gold-dim); margin-top:24px;
    position:relative; overflow:hidden; border-radius:1px;
    opacity:0; animation:loaderIn 0.6s 0.3s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .loader-line::after {
    content:''; position:absolute; top:0; left:-100%; width:100%; height:100%;
    background:linear-gradient(90deg, transparent, var(--gold), transparent);
    animation:loaderFill 1s 0.5s cubic-bezier(0.33,1,0.68,1) forwards;
  }
  @keyframes loaderIn { to { opacity:1; } }
  @keyframes loaderFill { to { left:100%; } }

  /* ═══════════════════════════════════════
     PRINT
     ═══════════════════════════════════════ */
  @media print {
    .cover { min-height:100vh; }
    .section { padding:60px; }
    .scroll-progress, .section-nav, .loader, .cover-cta, .scroll-indicator { display:none; }
    .photo-break { height:200px; page-break-inside:avoid; clip-path:none !important; }
    h2 em::after { width:100% !important; }
    .reveal { opacity:1 !important; transform:none !important; }
    .eyebrow::before { width:24px !important; }
    .grain-section::after { display:none; }
  }

  /* ═══════════════════════════════════════
     MOBILE
     ═══════════════════════════════════════ */
  @media (max-width:768px) {
    .cover-content, .cover-top { padding-left:32px; padding-right:32px; }
    .section { padding:80px 32px; }
    .scorecard, .channels, .pillars, .rhythm-grid, .steps, .numbers, .stats { grid-template-columns:1fr; }
    .rm { grid-template-columns:1fr; }
    .rm-left { border-right:none; border-bottom:2px solid var(--gold-dim); padding:24px 0; }
    .rm-left::after { display:none; }
    .rm-right { padding:24px 0; }
    .roadmap-line { display:none; }
    .cover-meta-bar { flex-direction:column; gap:16px; }
    .footer { padding:60px 32px; }
    .section-nav { display:none; }
    .photo-break { height:200px; min-height:200px; }
    .photo-break-caption { padding:12px 32px; }
    .scroll-indicator { display:none; }
    .comp-table { display:block; overflow-x:auto; }
    .channel { border-left:none !important; }
    .channel:hover { border-left:none !important; }
    .pillar { border-left:none !important; }
    .pillar:hover { border-left:none !important; }
    .insight { padding:32px; }
  }
</style>
</head>
<body>

<!-- LOADING SCREEN -->
<div class="loader" id="loader">
  <div class="loader-brand">Matt Anthony Photography</div>
  <div class="loader-sub">Marketing Playbook</div>
  <div class="loader-line"></div>
</div>

<div class="scroll-progress" id="scrollProgress"></div>
<nav class="section-nav" id="sectionNav"></nav>

<!-- ═══════ COVER ═══════ -->
<div class="cover">
  <div class="cover-image" id="coverImg" style="background-image:url('{{ cover.image_url }}');background-position:{{ cover.image_position | default('center 25%') }};"></div>
  <div class="cover-top">
    <div class="cover-logo">Matt Anthony Photography</div>
    <div class="cover-date">{{ plan.date }}</div>
  </div>
  <div class="cover-content">
    <div class="cover-eyebrow">{{ cover.eyebrow }}</div>
    <h1>{{ cover.headline_html | safe }}</h1>
    <p class="cover-sub">{{ cover.subtitle }}</p>
    <div class="cover-meta-bar">
      <div class="cover-meta-item"><strong>Prepared for</strong>{{ client.owner }}{% if client.owner_title %}, {{ client.owner_title }}{% endif %}</div>
      <div class="cover-meta-item"><strong>Company</strong>{{ client.company }}</div>
      <div class="cover-meta-item"><strong>Date</strong>{{ plan.date }}</div>
    </div>
    {% if cover.cta_text %}
    <a class="cover-cta" href="{{ cover.cta_target | default('#snapshot') }}"><span>{{ cover.cta_text }}</span><span class="cover-cta-arrow">&darr;</span></a>
    {% endif %}
  </div>
  <div class="scroll-indicator" id="scrollIndicator">
    <div class="scroll-indicator-text">Scroll</div>
    <div class="scroll-indicator-line"></div>
  </div>
</div>


{# ═══════ SECTION LOOP WITH PHOTO BREAKS ═══════ #}
{% for section_name in sections %}

{# ─── SNAPSHOT (Where You Stand) ─── #}
{% if section_name == "snapshot" and snapshot is defined %}
<div class="section cream" id="snapshot" data-nav="{{ snapshot.nav_label | default('Snapshot') }}">
  <div class="eyebrow">{{ snapshot.eyebrow }}</div>
  <h2>{{ snapshot.headline_html | safe }}</h2>
  <p class="lead">{{ snapshot.lead }}</p>
  {% for p in snapshot.paragraphs %}
  <p>{{ p | safe }}</p>
  {% endfor %}
  {% if snapshot.scores %}
  <div class="scorecard">
    {% for s in snapshot.scores %}
    <div class="score-item">
      <div class="score-ring" data-score="{{ s.value }}">
        <svg viewBox="0 0 80 80"><circle class="ring-bg" /><circle class="ring-fill {{ s.color | default('ok') }}" /></svg>
        <span class="score-grade">{{ s.grade }}</span>
      </div>
      <span class="score-label">{{ s.label }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% if snapshot.findings %}
  <div class="channels">
    {% for f in snapshot.findings %}
    <div class="channel">
      <div class="channel-status {{ f.status }}">{{ f.status_label }}</div>
      <h4>{{ f.area }}</h4>
      <ul>
        {% for point in f.points %}
        <li>{{ point | safe }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% if snapshot.insight %}
  <div class="insight">
    <h4>{{ snapshot.insight.title }}</h4>
    {{ snapshot.insight.content_html | safe }}
  </div>
  {% endif %}
</div>

{# ─── OPPORTUNITY (What Top Builders Do) ─── #}
{% elif section_name == "opportunity" and opportunity is defined %}
<div class="section" data-nav="{{ opportunity.nav_label | default('Opportunity') }}">
  <div class="eyebrow">{{ opportunity.eyebrow }}</div>
  <h2>{{ opportunity.headline_html | safe }}</h2>
  <p class="lead">{{ opportunity.lead }}</p>
  {% for p in opportunity.paragraphs %}
  <p>{{ p | safe }}</p>
  {% endfor %}
  {% if opportunity.competitors %}
  <table class="comp-table">
    <thead>
      <tr>
        <th>Builder</th>
        <th>Website</th>
        <th>Social</th>
        <th>GBP</th>
        <th>Photography</th>
        <th>Awards</th>
      </tr>
    </thead>
    <tbody>
      {% for c in opportunity.competitors %}
      <tr{% if c.is_you %} class="highlight"{% endif %}>
        <td><strong>{{ c.name }}</strong></td>
        <td><span class="comp-dot {{ c.website }}"></span>{{ c.website_note }}</td>
        <td><span class="comp-dot {{ c.social }}"></span>{{ c.social_note }}</td>
        <td><span class="comp-dot {{ c.gbp }}"></span>{{ c.gbp_note }}</td>
        <td><span class="comp-dot {{ c.photography }}"></span>{{ c.photography_note }}</td>
        <td><span class="comp-dot {{ c.awards }}"></span>{{ c.awards_note }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if opportunity.insight %}
  <div class="insight">
    <h4>{{ opportunity.insight.title }}</h4>
    {{ opportunity.insight.content_html | safe }}
  </div>
  {% endif %}
</div>

